@page
@model Dotnetstore.Hotel.Ui.Web.Pages.Roles.CreateModel
@{
    ViewData["Title"] = "Create role";
}

<h1 class="app-page-title h2">Create role</h1>
<p class="app-page-subtitle">Add a new role that staff accounts can be assigned.</p>

<div class="row">
    <div class="col-lg-6">
        <div class="app-card">
            @if (Model.Errors.Count > 0)
            {
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        @foreach (var error in Model.Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }
            <form method="post">
                <div class="mb-4">
                    <label asp-for="Name" class="form-label">Role name</label>
                    <input asp-for="Name" class="form-control" autocomplete="off" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn btn-brand">Create role</button>
            </form>
        </div>
    </div>
</div>
