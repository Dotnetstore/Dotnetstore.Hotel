@page "{id:guid}"
@model Dotnetstore.Hotel.Ui.Web.Pages.Roles.EditModel
@{
    ViewData["Title"] = "Edit role";
}

<h1 class="app-page-title h2">Edit role</h1>
<p class="app-page-subtitle">Rename this role.</p>

<div class="row">
    <div class="col-lg-6">
        <div class="app-card">
            @if (Model.IsProtected)
            {
                <div class="alert alert-danger">This role is required for admin access and cannot be renamed.</div>
            }
            @if (Model.Errors.Count > 0)
            {
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        @foreach (var error in Model.Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }
            <form method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-4">
                    <label asp-for="Name" class="form-label">Role name</label>
                    @if (Model.IsProtected)
                    {
                        <input asp-for="Name" class="form-control" autocomplete="off" readonly />
                    }
                    else
                    {
                        <input asp-for="Name" class="form-control" autocomplete="off" />
                    }
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    @if (Model.IsProtected)
                    {
                        <button type="submit" class="btn btn-brand" disabled>Save changes</button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-brand">Save changes</button>
                    }
                    <a class="btn btn-outline-secondary" asp-page="/Roles/Index">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
