@page "{id:guid}"
@model Dotnetstore.Hotel.Ui.Web.Pages.Room.EditModel
@{
    ViewData["Title"] = "Edit room";
}

<h1 class="app-page-title h2">Edit room</h1>
<p class="app-page-subtitle">Update this room.</p>

<div class="row">
    <div class="col-lg-8">
        <div class="app-card">
            @if (Model.Errors.Count > 0)
            {
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        @foreach (var error in Model.Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }
            <form method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-4">
                    <label asp-for="RoomNumber" class="form-label">Room number</label>
                    <input asp-for="RoomNumber" class="form-control" autocomplete="off" />
                    <span asp-validation-for="RoomNumber" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Floor" class="form-label">Floor</label>
                    <input asp-for="Floor" class="form-control" type="number" />
                </div>
                <div class="mb-4">
                    <label asp-for="Capacity" class="form-label">Capacity</label>
                    <input asp-for="Capacity" class="form-control" type="number" min="1" />
                </div>
                <div class="mb-4">
                    <label asp-for="BedType" class="form-label">Bed type</label>
                    <input asp-for="BedType" class="form-control" autocomplete="off" placeholder="e.g. Double, Twin, Suite" />
                    <span asp-validation-for="BedType" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="PricePerNight" class="form-label">Price per night</label>
                    <input asp-for="PricePerNight" class="form-control" type="number" step="0.01" min="0" />
                </div>
                <div class="mb-4">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        @foreach (var status in Model.Statuses)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label">Equipment</label>
                    @for (var i = 0; i < Model.EquipmentSelections.Count; i++)
                    {
                        var row = Model.EquipmentSelections[i];
                        <div class="border rounded p-3 mb-2">
                            <input type="hidden" asp-for="EquipmentSelections[i].EquipmentId" />
                            <input type="hidden" asp-for="EquipmentSelections[i].EquipmentName" />
                            <div class="form-check">
                                <input class="form-check-input" asp-for="EquipmentSelections[i].Included" />
                                <label class="form-check-label" asp-for="EquipmentSelections[i].Included">@row.EquipmentName</label>
                            </div>
                            @if (Model.AvailableTags.Count > 0)
                            {
                                <div class="ms-4 mt-2 d-flex flex-wrap gap-3">
                                    @foreach (var tag in Model.AvailableTags)
                                    {
                                        if (row.SelectedTagIds.Contains(tag.Id))
                                        {
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="EquipmentSelections[@i].SelectedTagIds" value="@tag.Id" id="tag-@i-@tag.Id" checked />
                                                <label class="form-check-label" for="tag-@i-@tag.Id">@tag.Name</label>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="EquipmentSelections[@i].SelectedTagIds" value="@tag.Id" id="tag-@i-@tag.Id" />
                                                <label class="form-check-label" for="tag-@i-@tag.Id">@tag.Name</label>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-brand">Save changes</button>
                    <a class="btn btn-outline-secondary" asp-page="/Room/Index">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
