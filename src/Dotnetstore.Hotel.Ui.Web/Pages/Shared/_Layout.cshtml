<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] is string t ? $"{t} · Dotnetstore Hotel" : "Dotnetstore Hotel")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-md app-navbar">
        <div class="container">
            <a class="navbar-brand app-brand" asp-page="/Hotel">
                <span class="app-brand-mark">DH</span> Dotnetstore Hotel
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav ms-auto align-items-md-center gap-1">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link" asp-page="/Hotel">Hotel</a></li>
                        @if (User.IsInRole("administrator") || User.IsInRole("superuser"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/Users/Index">Users</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Roles/Index">Roles</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Equipment/Index">Equipment</a></li>
                        }
                        <li class="nav-item ms-md-2">
                            <span class="nav-user-pill">@User.Identity!.Name</span>
                        </li>
                        <li class="nav-item">
                            <form method="post" asp-page="/Logout" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-light ms-md-2">Sign out</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-page="/Login">Sign in</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container app-main">
        @if (TempData["StatusMessage"] is string status)
        {
            <div class="alert alert-success app-alert" role="alert">@status</div>
        }
        @if (TempData["ErrorMessage"] is string error)
        {
            <div class="alert alert-danger app-alert" role="alert">@error</div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
