@page
@model Dotnetstore.Hotel.Ui.Web.Pages.Bookings.IndexModel
@{
    ViewData["Title"] = "Bookings";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
    <div>
        <h1 class="app-page-title h2">Bookings</h1>
        <p class="app-page-subtitle mb-0">Manage reservations.</p>
    </div>
    <a class="btn btn-brand" asp-page="/Bookings/Create">+ Create booking</a>
</div>

<div class="app-card p-0">
    <table class="table align-middle mb-0">
        <thead>
            <tr>
                <th class="ps-4">Customer</th>
                <th>Rooms</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Status</th>
                <th class="text-end pe-4">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.Bookings)
            {
                <tr>
                    <td class="ps-4">#@booking.Customer.CustomerNumber @booking.Customer.FullName</td>
                    <td>@string.Join(", ", booking.Rooms.Select(r => r.RoomNumber))</td>
                    <td>@booking.CheckInDate.ToString("yyyy-MM-dd")</td>
                    <td>@booking.CheckOutDate.ToString("yyyy-MM-dd")</td>
                    <td>@booking.Status</td>
                    <td class="text-end pe-4">
                        @if (booking.Status == "Reserved")
                        {
                            <form method="post" asp-page-handler="CheckIn" asp-route-id="@booking.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Check-in</button>
                            </form>
                            <form method="post" asp-page-handler="Cancel" asp-route-id="@booking.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                            </form>
                        }
                        else if (booking.Status == "CheckedIn")
                        {
                            <form method="post" asp-page-handler="CheckOut" asp-route-id="@booking.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Check-out</button>
                            </form>
                            <form method="post" asp-page-handler="Cancel" asp-route-id="@booking.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
