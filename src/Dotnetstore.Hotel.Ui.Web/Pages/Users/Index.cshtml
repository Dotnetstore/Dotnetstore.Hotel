@page
@model Dotnetstore.Hotel.Ui.Web.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
    <div>
        <h1 class="app-page-title h2">Users</h1>
        <p class="app-page-subtitle mb-0">Manage staff accounts, roles, and access.</p>
    </div>
    <a class="btn btn-brand" asp-page="/Users/Create">+ Create user</a>
</div>

<div class="app-card p-0">
    <table class="table align-middle mb-0">
        <thead>
            <tr>
                <th class="ps-4">Email</th>
                <th>Username</th>
                <th>Roles</th>
                <th>Status</th>
                <th class="text-end pe-4">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td class="ps-4">@user.Email</td>
                    <td>@user.UserName</td>
                    <td>
                        @foreach (var role in user.Roles)
                        {
                            <span class="app-amenity-pill">@role</span>
                        }
                    </td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge text-bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Deactivated</span>
                        }
                    </td>
                    <td class="text-end pe-4">
                        <a class="btn btn-sm btn-outline-secondary" asp-page="/Users/Edit" asp-route-id="@user.Id">Edit</a>
                        @if (user.IsActive)
                        {
                            <form method="post" asp-page-handler="Deactivate" asp-route-id="@user.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Deactivate</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Activate" asp-route-id="@user.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-success">Activate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
