@page
@model Dotnetstore.Hotel.Ui.Web.Pages.Tags.IndexModel
@{
    ViewData["Title"] = "Tags";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
    <div>
        <h1 class="app-page-title h2">Tags</h1>
        <p class="app-page-subtitle mb-0">Manage the catalog of tags that describe room equipment variants (e.g. "Hard", "55-inch").</p>
    </div>
    <a class="btn btn-brand" asp-page="/Tags/Create">+ Create tag</a>
</div>

<div class="app-card p-0">
    <table class="table align-middle mb-0">
        <thead>
            <tr>
                <th class="ps-4">Name</th>
                <th class="text-end pe-4">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tag in Model.Tags)
            {
                <tr>
                    <td class="ps-4">@tag.Name</td>
                    <td class="text-end pe-4">
                        <a class="btn btn-sm btn-outline-secondary" asp-page="/Tags/Edit" asp-route-id="@tag.Id">Edit</a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@tag.Id" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
